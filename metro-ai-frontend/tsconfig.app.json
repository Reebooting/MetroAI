{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],

    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    "moduleResolution": "bundler",

    "paths": {
      "@/*": ["./src/*"]
    },

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}